# Server
NODE_ENV=development
PORT=5000
CORS_ALLOWED_ORIGINS=http://localhost:3000
RECONCILIATION_WORKER_ENABLED=false
RECONCILIATION_WORKER_INTERVAL_MS=300000
RECONCILIATION_STALE_MINUTES=30

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=papafi
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papafi
POSTGRES_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papafi_test

# Auth/session
JWT_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=user@example.com
SMTP_PASS=replace-me
SMTP_FROM_EMAIL=no-reply@example.com

# Maplerad
MAPLERAD_BASE_URL=https://api.maplerad.com/v1
MAPLERAD_SECRET_KEY=replace-me
MAPLERAD_PUBLIC_KEY=replace-me
MAPLERAD_WEBHOOK_SECRET=replace-me
MAPLERAD_SIGNATURE_HEADER=x-maplerad-signature

# Legacy/unused integrations should not be required for Phase 1.
# Dojah is intentionally removed from active KY

STAGING_BASE_URL=http://localhost:5000