# Server
NODE_ENV=development
PORT=5000
CORS_ALLOWED_ORIGINS=http://localhost:3000
RECONCILIATION_WORKER_ENABLED=false
RECONCILIATION_WORKER_INTERVAL_MS=300000
RECONCILIATION_STALE_MINUTES=30
API_DOCS_ENABLED=false

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=papafi
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papafi
POSTGRES_TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/papafi_test

# Auth/session
JWT_SECRET=replace-with-long-random-secret
SESSION_SECRET=replace-with-long-random-secret

# Staging/dev smoke tests only. Never enable this in production.
ENABLE_TEST_OTP_BYPASS=false
TEST_OTP_CODE=123456
STAGING_BASE_URL=http://localhost:5000
SMOKE_TEST_EMAIL=
SMOKE_TEST_EMAIL_PREFIX=
SMOKE_TEST_RUN_ID=
SMOKE_TEST_PHONE=
SMOKE_TEST_PASSWORD=
SMOKE_TEST_PIN=

# Email (resend or smtp)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_HTTP_TIMEOUT_MS=10000
SMTP_FROM_EMAIL=noreply@mail.papifi.com

# SMTP fallback (used only when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=user@example.com
SMTP_PASS=replace-me

# Maplerad
MAPLERAD_ENVIRONMENT=sandbox
MAPLERAD_ALLOW_PRODUCTION_SANDBOX=false
MAPLERAD_ALLOW_CUSTOM_BASE_URL=false
MAPLERAD_SANDBOX_BASE_URL=https://api.maplerad.com/v1
MAPLERAD_SANDBOX_SECRET_KEY=replace-me
MAPLERAD_SANDBOX_PUBLIC_KEY=replace-me
MAPLERAD_SANDBOX_WEBHOOK_SECRET=
MAPLERAD_SANDBOX_PREVIOUS_WEBHOOK_SECRET=
MAPLERAD_PRODUCTION_BASE_URL=https://api.maplerad.com/v1
MAPLERAD_PRODUCTION_SECRET_KEY=replace-me
MAPLERAD_PRODUCTION_PUBLIC_KEY=replace-me
MAPLERAD_PRODUCTION_WEBHOOK_SECRET=
MAPLERAD_PRODUCTION_PREVIOUS_WEBHOOK_SECRET=
MAPLERAD_WEBHOOK_VERIFICATION_MODE=signature
MAPLERAD_WEBHOOK_ALLOWED_IPS=54.216.8.72,54.173.54.49,52.215.16.239,52.55.123.25,52.6.93.106,63.33.109.123,44.228.126.217,50.112.21.217,52.24.126.164,54.148.139.208
MAPLERAD_WEBHOOK_TOLERANCE_SECONDS=300
MAPLERAD_TRUST_PROXY=loopback
MAPLERAD_SANDBOX_TESTS_ENABLED=false
MAPLERAD_SANDBOX_CUSTOMER_CREATION_ENABLED=false
MAPLERAD_SANDBOX_WALLET_CREATION_ENABLED=false
MAPLERAD_SANDBOX_TEST_BVN=
MAPLERAD_SANDBOX_TEST_PHONE=
MAPLERAD_SANDBOX_TEST_EMAIL=
# Legacy fallback names, kept only during migration. Prefer environment-specific values above.
MAPLERAD_BASE_URL=
MAPLERAD_SECRET_KEY=
MAPLERAD_PUBLIC_KEY=

# Legacy/unused integrations should not be required for Phase 1.
# Dojah is intentionally removed from active KYC.
